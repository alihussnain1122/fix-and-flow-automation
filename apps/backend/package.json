{
  "name": "@fix-and-flow/backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "npm run build -w @fix-and-flow/types && npm run build -w @fix-and-flow/shared && tsx watch src/server.ts",
    "build": "tsc -p tsconfig.captcha.json && tsc",
    "start": "node dist/server.js",
    "start:pm2": "pm2 start ../../ecosystem.config.cjs",
    "db:migrate": "tsx src/db/migrate.ts",
    "playwright:install": "playwright install chromium chrome",
    "test:connectivity": "tsx src/scripts/test-connectivity.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@2captcha/captcha-solver": "^1.3.0",
    "@fix-and-flow/shared": "*",
    "@fix-and-flow/types": "*",
    "axios": "^1.7.7",
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "https-proxy-agent": "^7.0.6",
    "ioredis": "^5.4.1",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "playwright": "^1.46.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
