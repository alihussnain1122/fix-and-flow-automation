# Application
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=fixandflow
POSTGRES_PASSWORD=fixandflow_secret
POSTGRES_DB=fixandflow

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security
ENCRYPTION_KEY=change-me-to-32-char-secret-key!!

# BullMQ
QUEUE_PREFIX=fix-and-flow

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO=0
PLAYWRIGHT_NAV_RETRIES=3
PLAYWRIGHT_NAV_TIMEOUT=60000
PLAYWRIGHT_PROXY_FALLBACK=true
PLAYWRIGHT_BROWSER_CHANNEL=chrome
# Required if Facebook is blocked on your network (common in some regions):
# PLAYWRIGHT_GLOBAL_PROXY=http://username:password@proxy-host:port
# Facebook connect flow — opens a visible browser window (set true to hide)
PLAYWRIGHT_LOGIN_HEADLESS=false
# Max wait for 2FA / checkpoint in the visible browser (ms)
PLAYWRIGHT_LOGIN_TIMEOUT_MS=180000
# Captcha solving (2captcha required for reCAPTCHA grid; capsolver optional fallback)
TWOCAPTCHA_API_KEY=
CAPSOLVER_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Logging
LOG_LEVEL=info
