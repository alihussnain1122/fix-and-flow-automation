# Application
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=fixandflow
POSTGRES_PASSWORD=fixandflow_secret
POSTGRES_DB=fixandflow

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security
ENCRYPTION_KEY=change-me-to-32-char-secret-key!!

# BullMQ
QUEUE_PREFIX=fix-and-flow

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO=0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Logging
LOG_LEVEL=info
