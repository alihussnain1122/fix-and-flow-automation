# Application
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=fixandflow
POSTGRES_PASSWORD=fixandflow_secret
POSTGRES_DB=fixandflow

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security
ENCRYPTION_KEY=change-me-to-32-char-secret-key!!

# BullMQ
QUEUE_PREFIX=fix-and-flow

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO=0
PLAYWRIGHT_NAV_RETRIES=3
PLAYWRIGHT_NAV_TIMEOUT=60000
PLAYWRIGHT_PROXY_FALLBACK=true
PLAYWRIGHT_BROWSER_CHANNEL=chrome
# Required if Facebook is blocked on your network (common in some regions):
# PLAYWRIGHT_GLOBAL_PROXY=http://username:password@proxy-host:port
# Facebook connect flow — opens a visible browser window (set true to hide)
PLAYWRIGHT_LOGIN_HEADLESS=false
# Max wait for 2FA / checkpoint in the visible browser (ms)
PLAYWRIGHT_LOGIN_TIMEOUT_MS=180000
# Captcha: auto when TWOCAPTCHA_API_KEY is set (uses root captcha.ts + 2captcha)
# PLAYWRIGHT_CAPTCHA_MODE=manual   # force manual even with API key
TWOCAPTCHA_API_KEY=your_2captcha_key_here
# CAPSOLVER_API_KEY=
PLAYWRIGHT_CAPTCHA_MAX_ROUNDS=15
PLAYWRIGHT_CAPTCHA_CLEAR_MS=6000
PLAYWRIGHT_USE_STEALTH=true
CAPTCHA_LOG_PATH=logs/captcha.log
PLAYWRIGHT_LOGIN_TIMEOUT_MS=600000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Logging
LOG_LEVEL=info
